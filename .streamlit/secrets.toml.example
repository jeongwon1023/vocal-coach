# Streamlit Cloud secrets (copy to share.streamlit.io → Secrets)
# Local test: copy to .streamlit/secrets.toml (DO NOT commit)

OPENAI_API_KEY = "sk-your-key-here"
OPENAI_MODEL = "gpt-4o-mini"

# 강사 교재 RAG (coach_knowledge/ — repo에 포함)
COACH_RAG_ENABLED = "1"
COACH_RAG_TOP_K = "4"

# Supabase — 분석 기록 + 카카오 OAuth
# Dashboard → Project Settings → API
#   URL  → SUPABASE_URL
#   anon public key (eyJ...) 또는 publishable key (sb_publishable_...) → SUPABASE_KEY
SUPABASE_URL = "https://xxxx.supabase.co"
SUPABASE_KEY = "eyJhbGciOi... 또는 sb_publishable_..."

# OAuth redirect (Streamlit Cloud 앱 URL)
STREAMLIT_URL = "https://your-app.streamlit.app"

# 카카오 직접 로그인 (KOE205 방지 — Supabase Auth 대신 REST API 키 사용)
KAKAO_REST_API_KEY = "카카오_앱_REST_API_키"
# KAKAO_CLIENT_SECRET = "선택_카카오_로그인_클라이언트_시크릿"
