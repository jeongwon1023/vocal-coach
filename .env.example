# Vocal Coach AI — 환경 변수 (.env로 복사)

# OpenAI GPT 코칭 (선택)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# 강사 교재 RAG (기본 켜짐, 0이면 끔)
COACH_RAG_ENABLED=1
COACH_RAG_TOP_K=4

# Google OAuth — https://console.cloud.google.com/
# 리디렉션 URI: http://localhost:8001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao OAuth — https://developers.kakao.com/
# Redirect URI: http://localhost:8001/auth/kakao/callback
KAKAO_REST_API_KEY=

# 인증 서버 (run_web.bat 자동 기동)
AUTH_BASE_URL=http://localhost:8001
STREAMLIT_URL=http://localhost:8501

# Supabase (선택, Phase 2)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-anon-key
